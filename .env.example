# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (UK) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Flutterwave (Nigerian merchant, The 36th Solutions Ltd) ---
FLW_SECRET_KEY=

# --- Pricing: you control the customer FX rate ---
# NGN the customer gets per GBP 1 (set BELOW mid-market; the gap is your margin)
NGN_PER_GBP=2050
# Flat service fee in pence added to every order
SERVICE_FEE_PENCE=99
# Min/max order in NGN
MIN_ORDER_NGN=50
MAX_ORDER_NGN=500000

# --- WhatsApp Cloud API (reuse Nowrumble setup) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Approved template name (switch to nolgic_receipt once approved)
WHATSAPP_TEMPLATE=stillhome_receipt

# --- Founder alerts (Resend) ---
RESEND_API_KEY=
ALERT_EMAIL=azubuikedavies@gmail.com
ALERT_FROM=Nolgic <alerts@songsnap.online>
# Alert when NGN wallet drops below this
LOW_BALANCE_NGN=100000

# --- Receipts & cron ---
EMAIL_FROM=Nolgic <receipts@songsnap.online>
CRON_SECRET=
